    "node_004": {
      "id": "node_004",
      "speaker": {
        "name": "日和",
        "color": "#f9a8d4",
        "characterId": "hiyori"
      },
      "text": "我叫日和！也是今天刚入学的一年级生。那个……如果你不介意的话，要不要一起去找教室？",
      "background": "@/assets/galgalme/background/1.jpg",
      "characters": [
        {
          "characterId": "hiyori",
          "position": "right",
          "expression": "shy",
          "visible": true
        }
      ],
      "edges": [
        {
          "id": "e_004_005",
          "type": "choice",
          "label": "好啊，一起走吧",
          "target": "node_005"
        },
        {
          "id": "e_004_006",
          "type": "choice",
          "label": "……不用了，我自己找",
          "target": "node_006"
        }
      ]
    },
    "node_005": {
      "id": "node_005",
      "speaker": {
        "name": "日和",
        "color": "#f9a8d4",
        "characterId": "hiyori"
      },
      "text": "太好了！那我们走吧！",
      "background": "@/assets/galgalme/background/1.jpg",
      "characters": [
        {
          "characterId": "hiyori",
          "position": "right",
          "expression": "happy",
          "visible": true
