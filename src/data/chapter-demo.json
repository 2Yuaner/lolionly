      "speaker": {
        "name": "旁白",
        "color": "#aaaaaa"
      },
      "text": "我站在校门口，花瓣如雨般飘落。今天就是我高中生活的第一天。",
      "background": "@/assets/galgalme/background/1.jpg",
      "characters": [],
      "edges": [
        {
          "id": "e_002_003",
          "type": "auto",
          "target": "node_003"
        }
      ]
    },
    "node_003": {
      "id": "node_003",
      "speaker": {
        "name": "???",
        "color": "#f9a8d4"
      },
      "text": "那个……同学，你是新生吗？",
      "background": "@/assets/galgalme/background/1.jpg",
      "characters": [
        {
          "characterId": "hiyori",
          "position": "right",
          "expression": "neutral",
          "visible": true
