      "id": "node_006",
      "speaker": {
        "name": "日和",
        "color": "#f9a8d4",
        "characterId": "hiyori"
      },
      "text": "啊……这样啊……那、那好吧……",
      "background": "@/assets/galgalme/background/1.jpg",
      "characters": [
        {
          "characterId": "hiyori",
          "position": "right",
          "expression": "shy",
